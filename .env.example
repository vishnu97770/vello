# Vello — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# xAI Grok API key — OPTIONAL
# Vello works fully offline without this.
# Add your key only if you want AI fallback for unknown questions.
# Get a free key at: https://console.x.ai
XAI_API_KEY=

# Wake word (optional override)
# VELLO_WAKE_WORD=hey vello
